# ── Database (Supabase) ──────────────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection string → URI
# IMPORTANT: append ?sslmode=require for Supabase
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="your-jwt-secret-min-32-chars"
JWT_EXPIRES_IN="7d"

# ── GitHub OAuth App ─────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps
# Callback URL: https://your-railway-api.railway.app/auth/github/callback
GITHUB_CLIENT_ID="your-github-oauth-app-client-id"
GITHUB_CLIENT_SECRET="your-github-oauth-app-client-secret"

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ── GitHub Webhook ───────────────────────────────────────────────────────────
# Webhook URL: https://your-railway-api.railway.app/webhooks/github
GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# ── GitHub Personal Access Token (for reading PR diffs) ──────────────────────
GITHUB_TOKEN="your-github-pat"

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# Get from: Upstash Console → Redis → Connect → ioredis
# MUST use rediss:// (TLS) for Upstash — NOT redis://
REDIS_URL="rediss://default:[PASSWORD]@[HOST].upstash.io:6379"

# ── App ───────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not hardcode in production
PORT=3001
NODE_ENV="development"
# Set to your Vercel frontend URL in production (no trailing slash)
FRONTEND_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
