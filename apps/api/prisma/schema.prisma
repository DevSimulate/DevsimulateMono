datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

enum Stack {
  DOTNET
  NODE
  ANGULAR
  REACT
  SYSTEM_DESIGN
  PYTHON
  DEVOPS
  CPP
  JAVA
  DOTNETANGULAR
}

enum Difficulty {
  JUNIOR
  MID
  SENIOR
}

enum SubscriptionTier {
  FREE
  PRO
  COMPANY
}

enum SubmissionStatus {
  PENDING
  REVIEWED
  VOID
}

enum AIUsageDeclaration {
  NO_AI_USED
  AI_USED_FOR_PHRASING
  AI_USED_FOR_UNDERSTANDING
  AI_USED_FOR_ANSWER
}

model User {
  id                  String              @id @default(uuid())
  githubId            String?             @unique
  githubUsername      String?             @unique
  fullName            String?
  email               String?
  primaryStack        Stack               @default(NODE)
  subscriptionTier    SubscriptionTier    @default(FREE)
  skillScore          Int                 @default(0)
  githubAccessToken   String?
  // Integrity disqualification — set when a candidate is kicked out for repeated
  // paste attempts during an assessment. Blocks re-applying. Admin-reversible:
  // clear both fields to restore the account.
  disqualifiedAt      DateTime?
  disqualifiedReason  String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  submissions         Submission[]
  assignments         TicketAssignment[]
  subscription        Subscription?
  orgMemberships      OrgMember[]
  applications        Application[]
  campaignCandidates  CampaignCandidate[]
  certificates        Certificate[]
}

model Codebase {
  id          String     @id @default(uuid())
  name        String
  stack       Stack
  repoUrl     String
  description String
  companyLore String     @db.Text
  createdAt   DateTime   @default(now())
  tickets     Ticket[]
  campaigns   Campaign[]
}

model Ticket {
  id              String      @id @default(uuid())
  title           String
  description     String      @db.Text
  stack           Stack
  difficulty      Difficulty  @default(JUNIOR)
  filesInvolved   String[]
  rubric          Json
  expectedMinutes Int         @default(60)
  codebaseId      String
  codebase        Codebase    @relation(fields: [codebaseId], references: [id])
  createdAt       DateTime    @default(now())
  submissions     Submission[]
  assignments     TicketAssignment[]
  jobPosts        JobPost[]
}

model TicketAssignment {
  id         String   @id @default(uuid())
  userId     String
  ticketId   String
  branchName String
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id])

  @@unique([userId, ticketId])
}

enum OrgPlan {
  HIRING
  TRAINING
  ENTERPRISE
}

enum OrgRole {
  ADMIN
  MANAGER
  MEMBER
}

enum ApplicationStatus {
  INVITED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model Subscription {
  id                   String           @id @default(uuid())
  userId               String           @unique
  stripeCustomerId     String           @unique
  stripeSubscriptionId String?
  tier                 SubscriptionTier @default(FREE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  user                 User             @relation(fields: [userId], references: [id])
}

model Submission {
  id                 String              @id @default(uuid())
  userId             String
  ticketId           String
  prUrl              String?
  prDescription      String?             @db.Text
  branchName         String?
  designDoc          String?             @db.Text
  status             SubmissionStatus    @default(PENDING)
  scoreTotal         Int?
  scoreDiagnosis     Int?
  scoreDesign        Int?
  scoreCommunication Int?
  scoreExecution     Int?
  claudeReview       Json?
  graderResult       Json?               // hidden-test outcome from the CI grader: { ticketId, passed, at }
  scorePrBase        Int?                // raw Claude PR score before any deductions — never mutated after initial save
  verbalPenalty      Int                 @default(0)
  hiddenTestPenalty  Int                 @default(0)
  riskScore          Int                 @default(0)
  // True only once the FULL assessment is complete (verbal scored, or verbal not
  // applicable). Leaderboards/certificates show a submission only when finalized,
  // so a pre-verbal score never appears.
  finalized          Boolean             @default(false)
  pasteAttempts      Int                 @default(0)
  submittedAt        DateTime            @default(now())
  reviewedAt         DateTime?
  user               User                @relation(fields: [userId], references: [id])
  ticket             Ticket              @relation(fields: [ticketId], references: [id])
  applications       Application[]
  followUp           FollowUpQuestion?
  campaignCandidates CampaignCandidate[]
}

model FollowUpQuestion {
  id                  String                @id @default(uuid())
  submissionId        String                @unique
  submission          Submission            @relation(fields: [submissionId], references: [id])
  question1           String                @db.Text
  question2           String?               @db.Text
  answer1             String?               @db.Text
  answer2             String?               @db.Text
  scoreBonus          Int?
  claudeFeedback      String?               @db.Text
  aiDeclaration       AIUsageDeclaration?
  declarationMismatch Boolean               @default(false)
  employerSummary     String?               @db.Text
  verbalTranscript    String?               @db.Text  // spoken explanation, transcribed (audio not stored)
  verbalScore         Int?                            // 0-10 verbal understanding
  verbalNote          String?               @db.Text  // employer-facing note on spoken vs written
  answeredAt          DateTime?
  createdAt           DateTime              @default(now())
}

model Organisation {
  id           String      @id @default(uuid())
  name         String
  domain       String?
  plan         OrgPlan     @default(HIRING)
  stripeId     String?
  logoUrl      String?
  primaryColor String?
  accentColor  String?
  brandName    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  members      OrgMember[]
  jobPosts     JobPost[]
  campaigns    Campaign[]
}

model OrgMember {
  id       String   @id @default(uuid())
  orgId    String
  userId   String
  role     OrgRole  @default(MEMBER)
  joinedAt DateTime @default(now())
  org      Organisation @relation(fields: [orgId], references: [id])
  user     User         @relation(fields: [userId], references: [id])

  @@unique([orgId, userId])
}

model JobPost {
  id           String        @id @default(uuid())
  orgId        String
  ticketId     String
  title        String
  description  String?       @db.Text
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  org          Organisation  @relation(fields: [orgId], references: [id])
  ticket       Ticket        @relation(fields: [ticketId], references: [id])
  applications Application[]
}

model Application {
  id           String            @id @default(uuid())
  jobPostId    String
  userId       String
  submissionId String?
  status       ApplicationStatus @default(INVITED)
  invitedAt    DateTime          @default(now())
  completedAt  DateTime?
  jobPost      JobPost     @relation(fields: [jobPostId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
  submission   Submission? @relation(fields: [submissionId], references: [id])

  @@unique([jobPostId, userId])
}

model WaitlistEntry {
  id        String   @id @default(uuid())
  email     String
  codebase  String
  createdAt DateTime @default(now())

  @@unique([email, codebase])
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum CampaignType {
  HIRING
  CONTEST
}

enum CandidateStatus {
  NEW
  REVIEWED
  SHORTLISTED
  REJECTED
}

model Campaign {
  id             String              @id @default(cuid())
  orgId          String
  roleName       String
  codebaseId     String
  difficulty     Difficulty
  candidateLimit Int                 @default(100)
  deadline       DateTime?
  companyName    String
  bookingLink    String?
  shareableSlug  String              @unique
  ticketIds      String[]            @default([])
  type           CampaignType        @default(HIRING)
  status         CampaignStatus      @default(ACTIVE)
  devFestTag     String?
  // Proctoring policy for assessments run under this campaign. Admin-toggleable
  // via a simple UPDATE — the assessment page reads these at runtime instead of
  // hardcoding the behavior. Default strict.
  blockPaste        Boolean          @default(true)
  requireFullscreen Boolean          @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  org            Organisation        @relation(fields: [orgId], references: [id])
  codebase       Codebase            @relation(fields: [codebaseId], references: [id])
  candidates     CampaignCandidate[]
  certificates   Certificate[]
}

model CampaignCandidate {
  id           String          @id @default(cuid())
  campaignId   String
  userId       String
  submissionId String?
  status       CandidateStatus @default(NEW)
  invitedAt    DateTime?
  joinedAt     DateTime        @default(now())
  campaign     Campaign        @relation(fields: [campaignId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  submission   Submission?     @relation(fields: [submissionId], references: [id])
  decisions    CandidateDecision[]

  @@unique([campaignId, userId])
}

// Append-only audit trail of employer decisions. Proves human-in-the-loop:
// every status change records who made it, when, and whether the candidate
// was integrity-flagged at the moment of the decision.
model Certificate {
  id         String       @id @default(cuid())
  userId     String
  campaignId String
  score      Int
  rank       Int?
  category   String?      // DevFest category the rank is within (Frontend/Backend/DevOps · Infra/System Design)
  issuedAt   DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id])
  campaign   Campaign     @relation(fields: [campaignId], references: [id])

  @@unique([userId, campaignId])
}

model CandidateDecision {
  id          String            @id @default(cuid())
  candidateId String
  changedBy   String
  fromStatus  String
  toStatus    String
  wasFlagged  Boolean           @default(false)
  createdAt   DateTime          @default(now())
  candidate   CampaignCandidate @relation(fields: [candidateId], references: [id])

  @@index([candidateId])
}

// Participant feedback survey (DevFest / assessments). Public — a candidate opens
// the shareable /feedback link (optionally tagged with ?event=) and submits. Not
// tied to a user row so responses can stay anonymous.
model SurveyResponse {
  id                String   @id @default(uuid())
  event             String?  // e.g. "LMKR-DEVFEST-2026" — from the ?event= link param
  overallRating     Int?     // Q1  overall experience 1–5
  nps               Int?     // Q2  recommend 0–10
  vsTraditional     String?  // Q3  vs traditional assessments
  vsTraditionalWhy  String?  @db.Text
  ticketClear       Int?     // Q4  ticket clear 1–5
  ticketRealistic   Int?     // Q4  ticket realistic 1–5
  ticketChallenging Int?     // Q4  ticket appropriately challenging 1–5
  difficulty        String?  // Q5
  timeGiven         String?  // Q6
  instructionsClear String?  // Q7
  instructionsIssue String?  @db.Text
  aiFeel            String?  // Q8
  aiComments        String?  @db.Text
  verbalFeel        String?  // Q9
  verbalComments    String?  @db.Text
  fairChance        String?  // Q10
  technicalIssues   String[] // Q11 multi-select
  issueResolution   String?  // Q12
  bestPart          String?  @db.Text
  improve           String?  @db.Text
  contact           String?  // Q15 optional name/email
  userAgent         String?
  createdAt         DateTime @default(now())

  @@index([event])
}
